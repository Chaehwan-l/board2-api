{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://3.37.225.35:8080/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "http://3.37.225.35:8080/auth/:path*"
    },
    {
      "source": "/posts/:path*",
      "destination": "http://3.37.225.35:8080/posts/:path*"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "http://3.37.225.35:8080/oauth2/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
